{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@fgu/catalog/educational": ["../../packages/catalog/educational/index.ts"],
      "@fgu/catalog/educational/*": ["../../packages/catalog/educational/*"],
      "@fgu/renderer/rive": ["../../packages/renderer/rive/index.ts"],
      "@fgu/renderer/rive/*": ["../../packages/renderer/rive/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/catalog/educational/**/*.ts",
    "../../packages/catalog/educational/**/*.tsx",
    "../../packages/renderer/rive/**/*.ts",
    "../../packages/renderer/rive/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
